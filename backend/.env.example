# ─────────────────────────────────────────────────────
#  ReviseAI – Environment Variables Template
#  Copy this file to backend/.env and fill in the values
# ─────────────────────────────────────────────────────

# SQLite database path inside the container
# The /app/data directory is a Docker volume (data persists across restarts)
DATABASE_URL=sqlite:////app/data/reviseai.db

# Secret key used to sign JWT tokens
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_strong_random_secret_key
